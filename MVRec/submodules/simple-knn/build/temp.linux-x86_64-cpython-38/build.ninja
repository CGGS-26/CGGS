ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda-12.2/bin/nvcc

cflags = -pthread -B /home/sunzhenyu/anaconda3/envs/dreamscene360/compiler_compat -Wno-unused-result -Wsign-compare -DNDEBUG -fwrapv -O2 -Wall -fPIC -O2 -isystem /home/sunzhenyu/anaconda3/envs/dreamscene360/include -fPIC -O2 -isystem /home/sunzhenyu/anaconda3/envs/dreamscene360/include -fPIC -I/home/sunzhenyu/anaconda3/envs/dreamscene360/lib/python3.8/site-packages/torch/include -I/home/sunzhenyu/anaconda3/envs/dreamscene360/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/home/sunzhenyu/anaconda3/envs/dreamscene360/lib/python3.8/site-packages/torch/include/TH -I/home/sunzhenyu/anaconda3/envs/dreamscene360/lib/python3.8/site-packages/torch/include/THC -I/usr/local/cuda-12.2/include -I/home/sunzhenyu/anaconda3/envs/dreamscene360/include/python3.8 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_C -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -I/home/sunzhenyu/anaconda3/envs/dreamscene360/lib/python3.8/site-packages/torch/include -I/home/sunzhenyu/anaconda3/envs/dreamscene360/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/home/sunzhenyu/anaconda3/envs/dreamscene360/lib/python3.8/site-packages/torch/include/TH -I/home/sunzhenyu/anaconda3/envs/dreamscene360/lib/python3.8/site-packages/torch/include/THC -I/usr/local/cuda-12.2/include -I/home/sunzhenyu/anaconda3/envs/dreamscene360/include/python3.8 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_C -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags





build /projects/sunzhenyu/DreamScene360/submodules/simple-knn/build/temp.linux-x86_64-cpython-38/ext.o: compile /projects/sunzhenyu/DreamScene360/submodules/simple-knn/ext.cpp
build /projects/sunzhenyu/DreamScene360/submodules/simple-knn/build/temp.linux-x86_64-cpython-38/simple_knn.o: cuda_compile /projects/sunzhenyu/DreamScene360/submodules/simple-knn/simple_knn.cu
build /projects/sunzhenyu/DreamScene360/submodules/simple-knn/build/temp.linux-x86_64-cpython-38/spatial.o: cuda_compile /projects/sunzhenyu/DreamScene360/submodules/simple-knn/spatial.cu






